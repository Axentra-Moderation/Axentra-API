generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =========================================
// API Key (existing — linked to User for ownership)
// =========================================
model ApiKey {
  id         String    @id @default(uuid())
  keyHash    String    @unique
  prefix     String
  label      String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

// =========================================
// User Object — https://docs.discord.com/developers/resources/user#user-object
// =========================================
model User {
  id            String   @id
  username      String
  discriminator String
  globalName    String?  @map("global_name")
  avatar        String?
  bot           Boolean? @default(false)
  system        Boolean? @default(false)
  mfaEnabled    Boolean? @map("mfa_enabled")
  banner        String?
  accentColor   Int?     @map("accent_color")
  locale        String?
  verified      Boolean?
  email         String?
  flags         Int?
  premiumType   Int?     @map("premium_type")
  publicFlags   Int?     @map("public_flags")

  avatarDecorationData AvatarDecorationData?
  collectibles         Collectibles?
  primaryGuild         UserPrimaryGuild?

  apiKeys          ApiKey[]
  guildMemberships GuildMember[]
  ownedGuilds      Guild[]       @relation("GuildOwner")
  rolesCreated     Role[]        @relation("RoleBot")
  emojisCreated    Emoji[]       @relation("EmojiCreator")
  stickersCreated  Sticker[]     @relation("StickerCreator")
  bansReceived     Ban[]         @relation("BanTarget")
  bansIssued       Ban[]         @relation("BanModerator")
  logsReceived     Log[]         @relation("LogTarget")
  logsIssued       Log[]         @relation("LogModerator")
  messagesAuthored Message[]        @relation("MessageAuthor")
  messageMentions  MessageMention[] @relation("MentionedUser")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model AvatarDecorationData {
  id     String @id @default(uuid())
  asset  String
  skuId  String @map("sku_id")
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("avatar_decoration_data")
}

model Collectibles {
  id        String     @id @default(uuid())
  userId    String     @unique @map("user_id")
  user      User       @relation(fields: [userId], references: [id])
  nameplate Nameplate?

  @@map("collectibles")
}

model Nameplate {
  id             String       @id @default(uuid())
  skuId          String       @map("sku_id")
  asset          String
  label          String
  palette        String
  collectiblesId String       @unique @map("collectibles_id")
  collectibles   Collectibles @relation(fields: [collectiblesId], references: [id])

  @@map("nameplates")
}

model UserPrimaryGuild {
  id              String   @id @default(uuid())
  identityGuildId String?  @map("identity_guild_id")
  identityEnabled Boolean? @map("identity_enabled")
  tag             String?
  badge           String?
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id])

  @@map("user_primary_guilds")
}

// =========================================
// Guild Object — https://docs.discord.com/developers/resources/guild#guild-object
// =========================================
model Guild {
  id                          String   @id
  name                        String
  icon                        String?
  iconHash                    String?  @map("icon_hash")
  splash                      String?
  discoverySplash             String?  @map("discovery_splash")
  ownerId                     String   @map("owner_id")
  owner                       User     @relation("GuildOwner", fields: [ownerId], references: [id])
  region                      String?
  afkChannelId                String?  @map("afk_channel_id")
  afkTimeout                  Int      @map("afk_timeout")
  widgetEnabled               Boolean? @map("widget_enabled")
  widgetChannelId             String?  @map("widget_channel_id")
  verificationLevel           Int      @map("verification_level")
  defaultMessageNotifications Int      @map("default_message_notifications")
  explicitContentFilter       Int      @map("explicit_content_filter")
  mfaLevel                    Int      @map("mfa_level")
  applicationId               String?  @map("application_id")
  systemChannelId             String?  @map("system_channel_id")
  systemChannelFlags          Int      @map("system_channel_flags")
  rulesChannelId              String?  @map("rules_channel_id")
  maxPresences                Int?     @map("max_presences")
  maxMembers                  Int?     @map("max_members")
  vanityUrlCode               String?  @map("vanity_url_code")
  description                 String?
  banner                      String?
  premiumTier                 Int      @map("premium_tier")
  premiumSubscriptionCount    Int?     @map("premium_subscription_count")
  preferredLocale             String   @default("en-US") @map("preferred_locale")
  publicUpdatesChannelId      String?  @map("public_updates_channel_id")
  maxVideoChannelUsers        Int?     @map("max_video_channel_users")
  maxStageVideoChannelUsers   Int?     @map("max_stage_video_channel_users")
  approximateMemberCount      Int?     @map("approximate_member_count")
  approximatePresenceCount    Int?     @map("approximate_presence_count")
  nsfwLevel                   Int      @map("nsfw_level")
  premiumProgressBarEnabled   Boolean  @map("premium_progress_bar_enabled")
  safetyAlertsChannelId       String?  @map("safety_alerts_channel_id")

  features String[]

  welcomeScreen WelcomeScreen?
  incidentsData IncidentsData?

  roles    Role[]
  emojis   Emoji[]
  stickers Sticker[]

  members GuildMember[]
  bans    Ban[]
  logs    Log[]
  messages Message[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  settings Json

  @@map("guilds")
}

model WelcomeScreen {
  id              String                 @id @default(uuid())
  description     String?
  guildId         String                 @unique @map("guild_id")
  guild           Guild                  @relation(fields: [guildId], references: [id])
  welcomeChannels WelcomeScreenChannel[]

  @@map("welcome_screens")
}

model WelcomeScreenChannel {
  id              String        @id @default(uuid())
  channelId       String        @map("channel_id")
  description     String
  emojiId         String?       @map("emoji_id")
  emojiName       String?       @map("emoji_name")
  welcomeScreenId String        @map("welcome_screen_id")
  welcomeScreen   WelcomeScreen @relation(fields: [welcomeScreenId], references: [id])

  @@map("welcome_screen_channels")
}

model IncidentsData {
  id                   String    @id @default(uuid())
  invitesDisabledUntil DateTime? @map("invites_disabled_until")
  dmsDisabledUntil     DateTime? @map("dms_disabled_until")
  dmSpamDetectedAt     DateTime? @map("dm_spam_detected_at")
  raidDetectedAt       DateTime? @map("raid_detected_at")
  guildId              String    @unique @map("guild_id")
  guild                Guild     @relation(fields: [guildId], references: [id])

  @@map("incidents_data")
}

// =========================================
// Role Object — https://docs.discord.com/developers/topics/permissions#role-object
// =========================================
model Role {
  id             String  @id
  name           String
  color          Int?
  primaryColor   Int     @map("primary_color")
  secondaryColor Int?    @map("secondary_color")
  tertiaryColor  Int?    @map("tertiary_color")
  hoist          Boolean
  icon           String?
  unicodeEmoji   String? @map("unicode_emoji")
  position       Int
  permissions    String
  managed        Boolean
  mentionable    Boolean
  flags          Int

  tagBotId                 String?  @map("tag_bot_id")
  tagIntegrationId         String?  @map("tag_integration_id")
  tagPremiumSubscriber     Boolean? @map("tag_premium_subscriber")
  tagSubscriptionListingId String?  @map("tag_subscription_listing_id")
  tagAvailableForPurchase  Boolean? @map("tag_available_for_purchase")
  tagGuildConnections      Boolean? @map("tag_guild_connections")

  bot User? @relation("RoleBot", fields: [tagBotId], references: [id])

  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id])

  emojis Emoji[] @relation("EmojiRoles")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId])
  @@map("roles")
}

// =========================================
// Emoji Object — https://docs.discord.com/developers/resources/emoji#emoji-object
// =========================================
model Emoji {
  id            String   @id @default(uuid())
  discordId     String?  @map("discord_id")
  name          String?
  requireColons Boolean? @map("require_colons")
  managed       Boolean?
  animated      Boolean?
  available     Boolean?

  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id])

  creatorId String? @map("creator_id")
  creator   User?   @relation("EmojiCreator", fields: [creatorId], references: [id])

  roles Role[] @relation("EmojiRoles")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId])
  @@map("emojis")
}

// =========================================
// Sticker Object — https://docs.discord.com/developers/resources/sticker#sticker-object
// =========================================
enum StickerType {
  STANDARD
  GUILD
}

enum StickerFormatType {
  PNG
  APNG
  LOTTIE
  GIF
}

model Sticker {
  id          String            @id @default(uuid())
  discordId   String?           @map("discord_id")
  packId      String?           @map("pack_id")
  name        String
  description String?
  tags        String
  type        StickerType
  formatType  StickerFormatType @map("format_type")
  available   Boolean?
  sortValue   Int?              @map("sort_value")

  guildId String? @map("guild_id")
  guild   Guild?  @relation(fields: [guildId], references: [id])

  creatorId String? @map("creator_id")
  creator   User?   @relation("StickerCreator", fields: [creatorId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId])
  @@map("stickers")
}

// =========================================
// Guild Member Object — https://docs.discord.com/developers/resources/guild#guild-member-object
// =========================================
model GuildMember {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id])

  nick                       String?
  avatar                     String?
  banner                     String?
  roles                      String[]
  joinedAt                   DateTime? @map("joined_at")
  premiumSince               DateTime? @map("premium_since")
  deaf                       Boolean   @default(false)
  mute                       Boolean   @default(false)
  flags                      Int       @default(0)
  pending                    Boolean?  @default(false)
  permissions                String?
  communicationDisabledUntil DateTime? @map("communication_disabled_until")

  avatarDecorationData Json? @map("avatar_decoration_data")
  collectibles         Json?

  bans Ban[]
  logs Log[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, guildId])
  @@map("guild_members")
}

// =========================================
// Ban Object — https://docs.discord.com/developers/resources/guild#ban-object
// =========================================
model Ban {
  id     String  @id @default(uuid())
  reason String?

  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id])

  userId String @map("user_id")
  user   User   @relation("BanTarget", fields: [userId], references: [id])

  moderatorId String @map("moderator_id")
  moderator   User   @relation("BanModerator", fields: [moderatorId], references: [id])

  memberId String?      @map("member_id")
  member   GuildMember? @relation(fields: [memberId], references: [id])

  active    Boolean   @default(true)
  duration  Int?
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  logs      Log[]

  @@index([guildId, userId])
  @@index([guildId, memberId])
  @@map("bans")
}

// =========================================
// General Punishment / Log Object
// =========================================
enum LogAction {
  BAN
  UNBAN
  KICK
  MUTE
  UNMUTE
  WARN
  PARDON
  PURGE
}

model Log {
  id        String    @id @default(uuid())
  action    LogAction
  reason    String?
  duration  Int?
  expiresAt DateTime? @map("expires_at")
  amount    Int?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")

  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id])

  targetId String? @map("target_id")
  target   User?   @relation("LogTarget", fields: [targetId], references: [id])

  moderatorId String @map("moderator_id")
  moderator   User   @relation("LogModerator", fields: [moderatorId], references: [id])

  memberId String?      @map("member_id")
  member   GuildMember? @relation(fields: [memberId], references: [id])

  banId String?
  ban   Ban?    @relation(fields: [banId], references: [id])

  @@index([guildId])
  @@index([guildId, targetId])
  @@index([guildId, memberId])
  @@map("logs")
}

// =========================================
// Message Object — https://docs.discord.com/developers/resources/message#message-object
//
// NOTE: `channelId` is a plain string, not a relation — this schema has no
// `Channel` model yet. Add one and turn this into a real FK once channels
// are modeled.
//
// Rarely-queried nested structures are stored as raw `Json?` rather than
// full relational models, to avoid an explosion of one-off tables for data
// you'll mostly just display as-is: `messageSnapshots`, `interactionMetadata`,
// `roleSubscriptionData`, `sharedClientTheme`, `call`, `resolved`.
// =========================================

enum MessageType {
  DEFAULT
  RECIPIENT_ADD
  RECIPIENT_REMOVE
  CALL
  CHANNEL_NAME_CHANGE
  CHANNEL_ICON_CHANGE
  CHANNEL_PINNED_MESSAGE
  USER_JOIN
  GUILD_BOOST
  GUILD_BOOST_TIER_1
  GUILD_BOOST_TIER_2
  GUILD_BOOST_TIER_3
  CHANNEL_FOLLOW_ADD
  GUILD_DISCOVERY_DISQUALIFIED
  GUILD_DISCOVERY_REQUALIFIED
  GUILD_DISCOVERY_GRACE_PERIOD_INITIAL_WARNING
  GUILD_DISCOVERY_GRACE_PERIOD_FINAL_WARNING
  THREAD_CREATED
  REPLY
  CHAT_INPUT_COMMAND
  THREAD_STARTER_MESSAGE
  GUILD_INVITE_REMINDER
  CONTEXT_MENU_COMMAND
  AUTO_MODERATION_ACTION
  ROLE_SUBSCRIPTION_PURCHASE
  INTERACTION_PREMIUM_UPSELL
  STAGE_START
  STAGE_END
  STAGE_SPEAKER
  STAGE_TOPIC
  GUILD_APPLICATION_PREMIUM_SUBSCRIPTION
  GUILD_INCIDENT_ALERT_MODE_ENABLED
  GUILD_INCIDENT_ALERT_MODE_DISABLED
  GUILD_INCIDENT_REPORT_RAID
  GUILD_INCIDENT_REPORT_FALSE_ALARM
  PURCHASE_NOTIFICATION
  POLL_RESULT
}

model Message {
  id        String  @id // snowflake
  channelId String  @map("channel_id")

  authorId String? @map("author_id")
  author   User?   @relation("MessageAuthor", fields: [authorId], references: [id])

  guildId String? @map("guild_id")
  guild   Guild?  @relation(fields: [guildId], references: [id])

  content         String?
  timestamp       DateTime
  editedTimestamp DateTime? @map("edited_timestamp")
  tts             Boolean   @default(false)
  mentionEveryone Boolean   @default(false) @map("mention_everyone")
  mentionRoleIds  String[]  @map("mention_role_ids")

  mentions       MessageMention[]
  attachments    MessageAttachment[]
  embeds         MessageEmbed[]
  reactions      MessageReaction[]

  nonce        String?
  pinned       Boolean  @default(false)
  webhookId    String?  @map("webhook_id")
  type         MessageType
  flags        Int?

  applicationId String? @map("application_id")

  messageReference MessageReference?

  // Rarely-queried nested data — kept as raw JSON rather than full models.
  messageSnapshots     Json? @map("message_snapshots")
  interactionMetadata  Json? @map("interaction_metadata")
  roleSubscriptionData Json? @map("role_subscription_data")
  sharedClientTheme    Json? @map("shared_client_theme")
  call                 Json?
  resolved             Json?

  position Int?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId])
  @@index([channelId])
  @@index([authorId])
  @@map("messages")
}

// =========================================
// Message Mention (denormalized join — which users were @mentioned)
// =========================================
model MessageMention {
  id String @id @default(uuid())

  messageId String  @map("message_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("MentionedUser", fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([messageId])
  @@map("message_mentions")
}

// =========================================
// Attachment Object — https://docs.discord.com/developers/resources/message#attachment-object
// =========================================
model MessageAttachment {
  id String @id // snowflake

  messageId String  @map("message_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  filename      String
  title         String?
  description   String?
  contentType   String? @map("content_type")
  size          Int
  url           String
  proxyUrl      String  @map("proxy_url")
  height        Int?
  width         Int?
  ephemeral     Boolean? @default(false)
  durationSecs  Float?   @map("duration_secs")
  waveform      String?
  flags         Int?

  @@index([messageId])
  @@map("message_attachments")
}

// =========================================
// Embed Object — https://docs.discord.com/developers/resources/message#embed-object
// =========================================
model MessageEmbed {
  id String @id @default(uuid())

  messageId String  @map("message_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  title       String?
  type        String? // always "rich" for webhook embeds
  description String?
  url         String?
  timestamp   DateTime?
  color       Int?
  flags       Int?

  footer    MessageEmbedFooter?
  image     MessageEmbedMedia?  @relation("EmbedImage")
  thumbnail MessageEmbedMedia?  @relation("EmbedThumbnail")
  video     MessageEmbedMedia?  @relation("EmbedVideo")
  provider  MessageEmbedProvider?
  author    MessageEmbedAuthor?
  fields    MessageEmbedField[]

  @@index([messageId])
  @@map("message_embeds")
}

model MessageEmbedFooter {
  id           String       @id @default(uuid())
  text         String
  iconUrl      String?      @map("icon_url")
  proxyIconUrl String?      @map("proxy_icon_url")

  embedId String       @unique @map("embed_id")
  embed   MessageEmbed @relation(fields: [embedId], references: [id], onDelete: Cascade)

  @@map("message_embed_footers")
}

// Shared shape for image/thumbnail/video — Discord defines image & video
// separately but they're structurally identical aside from a couple fields,
// so this single model covers all three via the relation name.
model MessageEmbedMedia {
  id                 String  @id @default(uuid())
  url                String?
  proxyUrl           String? @map("proxy_url")
  height             Int?
  width              Int?
  contentType        String? @map("content_type")
  placeholder        String?
  placeholderVersion Int?    @map("placeholder_version")
  description        String?
  flags              Int?

  embedAsImageId     String? @unique @map("embed_as_image_id")
  embedAsImage       MessageEmbed? @relation("EmbedImage", fields: [embedAsImageId], references: [id], onDelete: Cascade)

  embedAsThumbnailId String? @unique @map("embed_as_thumbnail_id")
  embedAsThumbnail   MessageEmbed? @relation("EmbedThumbnail", fields: [embedAsThumbnailId], references: [id], onDelete: Cascade)

  embedAsVideoId     String? @unique @map("embed_as_video_id")
  embedAsVideo       MessageEmbed? @relation("EmbedVideo", fields: [embedAsVideoId], references: [id], onDelete: Cascade)

  @@map("message_embed_media")
}

model MessageEmbedProvider {
  id   String  @id @default(uuid())
  name String?
  url  String?

  embedId String       @unique @map("embed_id")
  embed   MessageEmbed @relation(fields: [embedId], references: [id], onDelete: Cascade)

  @@map("message_embed_providers")
}

model MessageEmbedAuthor {
  id           String  @id @default(uuid())
  name         String
  url          String?
  iconUrl      String? @map("icon_url")
  proxyIconUrl String? @map("proxy_icon_url")

  embedId String       @unique @map("embed_id")
  embed   MessageEmbed @relation(fields: [embedId], references: [id], onDelete: Cascade)

  @@map("message_embed_authors")
}

model MessageEmbedField {
  id     String  @id @default(uuid())
  name   String
  value  String
  inline Boolean? @default(false)

  embedId String       @map("embed_id")
  embed   MessageEmbed @relation(fields: [embedId], references: [id], onDelete: Cascade)

  @@index([embedId])
  @@map("message_embed_fields")
}

// =========================================
// Reaction Object — https://docs.discord.com/developers/resources/message#reaction-object
// =========================================
model MessageReaction {
  id String @id @default(uuid())

  messageId String  @map("message_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  count        Int
  countBurst   Int     @default(0) @map("count_burst")
  countNormal  Int     @default(0) @map("count_normal")
  me           Boolean @default(false)
  meBurst      Boolean @default(false) @map("me_burst")

  emojiId   String? @map("emoji_id")
  emojiName String? @map("emoji_name")

  burstColors String[] @map("burst_colors")

  @@unique([messageId, emojiId, emojiName])
  @@index([messageId])
  @@map("message_reactions")
}

// =========================================
// Message Reference Object — https://docs.discord.com/developers/resources/message#message-reference-object
// =========================================
model MessageReference {
  id String @id @default(uuid())

  messageId String  @unique @map("message_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  type              Int     @default(0) // 0 = DEFAULT, 1 = FORWARD
  referencedMessageId String? @map("referenced_message_id")
  channelId         String? @map("channel_id")
  guildId           String? @map("guild_id")
  failIfNotExists   Boolean? @default(true) @map("fail_if_not_exists")

  @@map("message_references")
}
